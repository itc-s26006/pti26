```gitignore
# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# C拡張
*.so

# -----------------------------
# 仮想環境 (venv)
# -----------------------------
venv/
.venv/
env/
ENV/

# -----------------------------
# テスト・カバレッジ
# -----------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# 型チェック
# -----------------------------
.mypy_cache/
.pyre/
.pytype/

# -----------------------------
# リンター・フォーマッタ
# -----------------------------
.ruff_cache/

# -----------------------------
# IDE・エディタ
# -----------------------------
.vscode/
.idea/

# -----------------------------
# Jupyter Notebook
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# ビルド成果物
# -----------------------------
build/
dist/
*.egg-info/

# -----------------------------
# 環境変数
# -----------------------------
.env
.env.*
```

